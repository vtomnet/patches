+/// Update the cached appearance used to answer `CSI ? 996 n` queries, and — if
+/// the appearance changed and the app has subscribed via DEC mode 2031 —
+/// return the `CSI ? 997 ; Ps n` notification bytes the host should write to
+/// the PTY.
+pub(super) fn set_color_scheme(term: &mut GhosttyTerm, is_dark: bool) -> Option<&'static [u8]> {
+    let scheme = if is_dark { 1 } else { 2 };
+    if term.color_scheme.swap(scheme, Ordering::Relaxed) == scheme {
+        return None;
+    }
+    if term.term.mode(Mode::COLOR_SCHEME_REPORT).unwrap_or(false) {
+        Some(if is_dark {
+            b"\x1b[?997;1n"
+        } else {
+            b"\x1b[?997;2n"
+        })
+    } else {
+        None
+    }
+}
