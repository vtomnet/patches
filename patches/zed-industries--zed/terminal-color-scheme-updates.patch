+    /// libghostty-vt parses OSC color operations but silently drops queries
+    /// (the `.query` branch in stream_terminal.zig is a no-op), so `OSC 10/11 ; ?`
+    /// must be answered here. Apps like nvim and opencode detect light/dark by
+    /// querying OSC 11, re-querying when a mode-2031 notification arrives. The
+    /// scan is chunk-local: a query split across two PTY reads goes unanswered,
+    /// which clients tolerate (they treat these queries as best-effort already).
+    fn answer_color_queries(&mut self, bytes: &[u8]) {
+        let mut rest = bytes;
+        while let Some(position) = rest.windows(2).position(|window| window == b"\x1b]") {
+            let body = &rest[position + 2..];
+            rest = body;
+            let (code, color) = if body.starts_with(b"10;?") {
+                ("10", self.term.fg_color())
+            } else if body.starts_with(b"11;?") {
+                ("11", self.term.bg_color())
+            } else {
+                continue;
+            };
+            let terminator = if body.get(4) == Some(&0x07) {
+                "\x07"
+            } else if body.get(4..6) == Some(b"\x1b\\") {
+                "\x1b\\"
+            } else {
+                continue;
+            };
